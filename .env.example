# ─── Zamolxis configuration ───────────────────────────────────────────────
# Copy to .env and adjust. ALL values are optional; sane defaults apply.

# Where persisted state lives (sessions, per-conversation workspaces, jobs, skills).
# Default: ~/.zamolxis
# ZAMOLXIS_DATA_DIR=

# The agent's display name (how it identifies itself; shown in the web UI).
# Also editable live from the web Settings panel. Default: Zamolxis
# ZAMOLXIS_AGENT_NAME=

# Inject the inviolable safety LAWS into the system prompt (default true). There's
# also a checkbox in the web Settings to toggle this live (e.g. to compare speed).
# ZAMOLXIS_LAWS_ENABLED=true

# ─── Auth (SUBSCRIPTION-FUNDED) ──────────────────────────────────────────────
# Zamolxis runs on your Claude Pro/Max subscription via `claude login`.
# Run `claude login` once before starting. Do NOT set ANTHROPIC_API_KEY — if it
# is present it is hidden from the engine so the subscription is used.
# Set this to 1 ONLY if you deliberately want metered API billing instead:
# ZAMOLXIS_ALLOW_API_KEY=0
#
# RECOMMENDED on macOS (and any headless/background setup): `claude login` stores the
# token in the OS Keychain, which the background engine often CAN'T read. Generate a
# long-lived token with `claude setup-token` and paste it here — works headless, no Keychain needed:
# CLAUDE_CODE_OAUTH_TOKEN=

# ─── Model routing (within the Claude family — free on the subscription) ─────
# Aliases 'opus' | 'sonnet' | 'haiku', or a full model id. Empty = CLI default.
# ZAMOLXIS_MODEL=
# Fast model: automatically used for SIMPLE Claude turns (the primary model above
# handles complex ones / anything escalated from the local model). A per-chat model
# picker in the web UI overrides this.
# ZAMOLXIS_FAST_MODEL=haiku
# Smartest model: used when a local-model turn ESCALATES (it couldn't cope) so the
# best model takes over and can author a skill for next time. Default: opus.
# ZAMOLXIS_SMART_MODEL=opus

# Optional on-device model for offloading EASY subtasks (free, conserves quota).
# Set up with: install.ps1 -Local  (or  install.sh --local) -- it detects your hardware,
# only offers a local model if the machine is powerful enough (dedicated GPU or >=8GB RAM),
# then shows a MENU of models that fit (each with its strength: best all-round / fast /
# coding / reasoning) and installs the one you pick. Add -Yes/--yes to take the recommended
# unattended; -Bigger/--bigger to default to the largest fit; -Force/--force to go below the bar.
# Expects an OpenAI-compatible endpoint (Ollama default below). The core agent
# stays on Claude; this is only an offload helper for trivial work.
# ZAMOLXIS_LOCAL_MODEL=llama3.2:3b
# ZAMOLXIS_LOCAL_MODEL_URL=http://localhost:11434/v1
# Routing: 'auto' = answer SIMPLE turns with the local model (no subscription used)
# and escalate anything needing tools/web/memory to Claude; 'off' = always use Claude
# (local stays an offload tool only). Defaults to 'auto' when a local model is set.
# Per-chat overrides (Auto/Local/Claude) are available in the web UI.
# ZAMOLXIS_LOCAL_ROUTING=auto

# ─── Behaviour ───────────────────────────────────────────────────────────────
# Permission posture: default | acceptEdits | bypassPermissions | plan | dontAsk
ZAMOLXIS_PERMISSION_MODE=acceptEdits
# Comma-separated tool denylist (always blocked).
# ZAMOLXIS_DISALLOWED_TOOLS=
# Max concurrent agent turns across all channels (subscription backpressure).
ZAMOLXIS_MAX_CONCURRENT=2
# Hard ceiling on turns per inbound message.
ZAMOLXIS_MAX_TURNS=40
# Wall-clock timeout per message (seconds). A stuck turn is aborted so it can't jam the queue.
ZAMOLXIS_TURN_TIMEOUT_SECONDS=300
# Extra instructions appended to the system prompt.
# ZAMOLXIS_SYSTEM_APPEND=

# ─── Channels (enable per surface) ───────────────────────────────────────────
ZAMOLXIS_CHANNEL_CLI=true
ZAMOLXIS_CHANNEL_TELEGRAM=false
ZAMOLXIS_CHANNEL_DISCORD=false
ZAMOLXIS_CHANNEL_SLACK=false
ZAMOLXIS_CHANNEL_WHATSAPP=false
ZAMOLXIS_CHANNEL_SIGNAL=false
ZAMOLXIS_CHANNEL_EMAIL=false
ZAMOLXIS_CHANNEL_WEB=false

# ─── Web interface ───────────────────────────────────────────────────────────
# Browser chat UI + Settings panel. Enable with ZAMOLXIS_CHANNEL_WEB=true.
ZAMOLXIS_WEB_PORT=8787
# Bind address: 127.0.0.1 = local only (safe). 0.0.0.0 = reachable on your network.
ZAMOLXIS_WEB_BIND=127.0.0.1
# REQUIRED if BIND is not loopback (the agent can run commands — never expose it
# unauthenticated). Any non-loopback bind without a token refuses to start.
# ZAMOLXIS_WEB_AUTH_TOKEN=

# Channel credentials. All of these can ALSO be set from the web Settings panel
# (stored in ~/.zamolxis/settings.json and applied on restart).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=     # comma-sep usernames (no @) and/or numeric ids; blank = anyone
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SIGNAL_NUMBER=              # +15551234567
# SIGNAL_CLI_PATH=            # blank = signal-cli on PATH
# EMAIL_USER=
# EMAIL_PASSWORD=
# EMAIL_IMAP_HOST=
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=465
# EMAIL_FROM=                 # blank = EMAIL_USER
# (WhatsApp uses a QR pairing flow on first run — no token)

# ─── Sandbox backends (sandbox_exec tool) ────────────────────────────────────
# Default backend when a tool call doesn't specify one: local | docker | ssh | modal
ZAMOLXIS_SANDBOX_BACKEND=local
# Local shell override (defaults: POSIX sh; on Windows prefers git-bash, else PowerShell)
# ZAMOLXIS_LOCAL_SHELL=
# Docker: set an image to enable the docker backend (optionally reuse a container)
# ZAMOLXIS_DOCKER_IMAGE=alpine:latest
# ZAMOLXIS_DOCKER_CONTAINER=
# SSH: set host+user to enable the ssh backend
# ZAMOLXIS_SSH_HOST=
# ZAMOLXIS_SSH_USER=
# ZAMOLXIS_SSH_PORT=22
# ZAMOLXIS_SSH_IDENTITY=
# Modal: needs the `modal` CLI + these tokens; uses src/sandbox/modal_runner.py
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
# ZAMOLXIS_MODAL_RUNNER=

# ─── Optional paid plugins (NOT subscription-funded — key-gated) ─────────────
# Image generation tool appears only if OPENAI_API_KEY is set (OpenAI gpt-image-1).
# Cross-provider model router appears if OPENAI_API_KEY and/or OPENROUTER_API_KEY set.
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# ─── Home Assistant (optional) ───────────────────────────────────────────────
# Lets the agent read HA entity states via the http_get tool (the "home-assistant"
# skill). http_get auto-attaches this token for the HA host, so it stays out of
# skills/prompts. Read-only (GET). Token = a HA long-lived access token.
# ZAMOLXIS_HA_URL=http://homeassistant.local:8123
# ZAMOLXIS_HA_TOKEN=

# ─── Routing chain (which models, in what order) ─────────────────────────────
# Ordered list of backends to try; each hands off to the next when it can't cope.
# Tokens: local | freecloud (rotate free providers) | <providerId> | claude.
# Drop 'claude' to run ONLY on local/free/paid. Edit it in the web "Providers" panel.
# ZAMOLXIS_ROUTE_CHAIN=local,freecloud,claude
# Examples:  local            (only on-device)
#            local,freecloud  (local + free cloud, no subscription)
#            local,deepseek,claude   (local → paid DeepSeek → Claude)
#
# Provider keys (free tiers: one key per provider — multiple accounts per provider
# breaks ToS; stacking across providers is fine). Manage in the Providers panel.
# GOOGLE_AI_API_KEY=     # aistudio.google.com/apikey  (free, Gemini 2.5 Flash ~1500/day)
# CEREBRAS_API_KEY=      # cloud.cerebras.ai           (free, ultra-fast; gpt-oss-120b)
# GROQ_API_KEY=          # console.groq.com/keys       (free, fast)
# MISTRAL_API_KEY=       # console.mistral.ai          (free)
# DEEPSEEK_API_KEY=      # platform.deepseek.com       (PAID, very cheap)
# (OPENROUTER_API_KEY above = free :free models; OPENAI_API_KEY above = paid 'openai' tier)

# ─── Web search (no key required) ────────────────────────────────────────────
# web_search works out of the box via DuckDuckGo (no key) for BOTH Claude and the
# local model. Optional higher-quality / self-hosted providers (first one set wins,
# in this order): Tavily key > Brave key > SearXNG URL > DuckDuckGo (default).
# TAVILY_API_KEY=
# BRAVE_API_KEY=
# ZAMOLXIS_SEARXNG_URL=http://localhost:8888   # your self-hosted SearXNG instance

# ─── External skill libraries (read-only, auto-discovered) ───────────────────
# Zamolxis auto-detects a Hermes install and surfaces the RELEVANT skills per request
# (Windows: %LOCALAPPDATA%\hermes\hermes-agent\{skills,optional-skills}; also ~/.hermeslite/skills).
# Browse + "Import" them in the web Skills panel to make any your own. Add more roots
# (each scanned recursively for SKILL.md); ; or , separated absolute paths:
# ZAMOLXIS_EXTRA_SKILLS_DIRS=

# ─── Logging ─────────────────────────────────────────────────────────────────
# ZAMOLXIS_LOG_LEVEL=info   # debug | info | warn | error
