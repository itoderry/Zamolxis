# Normalize line endings. Repo stores LF; Windows checkouts get CRLF where it matters.
* text=auto eol=lf

# Windows-only scripts must stay CRLF.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Shell scripts MUST stay LF (CRLF breaks the shebang on Linux/macOS).
*.sh text eol=lf

# Binary-ish assets (none yet, but safe defaults).
*.png binary
*.jpg binary
*.ico binary
